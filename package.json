{
	"name": "@wpsyntex/e2e-test-utils",
	"version": "0.1.1",
	"description": "End-to-end test utilities for Polylang projects.",
	"main": "./build/index.cjs",
	"exports": {
		".": {
			"default": "./build/index.cjs"
		}
	},
	"files": [
		"build"
	],
	"scripts": {
		"build": "node build.mjs",
		"clean": "rimraf build",
		"prepublishOnly": "npm run clean && npm run build",
		"prepare": "npm run build",
		"lint:js": "wp-scripts lint-js"
	},
	"keywords": [
		"polylang",
		"e2e",
		"playwright",
		"wordpress"
	],
	"author": "WP Syntex",
	"license": "GPL-2.0-or-later",
	"homepage": "https://github.com/polylang/e2e-test-utils/tree/HEAD/README.md",
	"repository": {
		"type": "git",
		"url": "https://github.com/polylang/e2e-test-utils.git"
	},
	"bugs": {
		"url": "https://github.com/polylang/e2e-test-utils/issues"
	},
	"engines": {
		"node": ">=18.12.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@playwright/test": ">=1",
		"@wordpress/e2e-test-utils-playwright": ">=1"
	},
	"devDependencies": {
		"@wordpress/scripts": "^32.6.0",
		"esbuild": "^0.28.1",
		"eslint": "^9.39.5",
		"glob": "^11.0.0",
		"rimraf": "^6.0.1"
	}
